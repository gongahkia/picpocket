{
  "name": "picpocket",
  "version": "1.0.0",
  "description": "Live presentation screen sharing for audiences in the room.",
  "main": "server.js",
  "scripts": {
    "audit": "npm audit --omit=dev",
    "format:check": "prettier --check \"**/*.{js,json,md,html,yml,yaml}\"",
    "lint": "eslint .",
    "start": "node server.js",
    "test": "node --test test/*.test.js",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "presentations",
    "screensharing",
    "websocket",
    "express"
  ],
  "author": "Gabriel Ong and Samuel Ang",
  "license": "MIT",
  "dependencies": {
    "express": "^4.22.2",
    "qrcode": "^1.5.3",
    "sharp": "^0.34.5",
    "unique-names-generator": "^4.7.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.7.4"
  }
}
